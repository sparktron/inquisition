{
  "_comment": "Example fleet config: scan several authorized targets with per-target settings. Use with: inquisition --fleet-config examples/fleet.json --yes",
  "defaults": {
    "depth": "standard",
    "sla_max_age": 5
  },
  "targets": [
    "marketing.example.com",
    {
      "target": "api.example.com",
      "depth": "deep",
      "sla_by_severity": {"critical": 1, "high": 3},
      "auth_header": "Authorization: Bearer REPLACE_WITH_TOKEN"
    },
    {
      "target": "legacy.example.com",
      "ports": [80, 443, 8080, 8443],
      "timeout": 20
    }
  ]
}
