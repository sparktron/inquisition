{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping Inquisition's /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "title": "Inquisition Security Scans",
  "uid": "inquisition-overview",
  "tags": ["inquisition", "security"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {"from": "now-7d", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "target",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(inquisition_findings_total, target)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"},
        "label": "Target"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Total findings over time",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10}}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "sum by (target) (inquisition_findings_total{target=~\"$target\"})",
         "legendFormat": "{{target}}"}
      ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Findings by severity",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "sum by (severity) (inquisition_findings{target=~\"$target\"})",
         "legendFormat": "{{severity}}", "instant": true}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Oldest finding age (scans)",
      "description": "Tracks SLA aging — a finding open across many scans has not been remediated.",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 5}, "unit": "none"}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "max by (target) (inquisition_finding_max_age_scans{target=~\"$target\"})",
         "legendFormat": "{{target}}"}
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Risk score",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 20},
            {"color": "orange", "value": 50},
            {"color": "red", "value": 100}
          ]}
        },
        "overrides": []
      },
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "inquisition_risk_score{target=~\"$target\"}",
         "legendFormat": "{{target}}", "instant": true}
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Open CVEs",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "sum (inquisition_cves_total{target=~\"$target\"})", "instant": true}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scan duration (s)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 5}, "unit": "s"}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "inquisition_scan_duration_seconds{target=~\"$target\"}",
         "legendFormat": "{{target}}"}
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Misconfigurations",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}]}}, "overrides": []},
      "targets": [
        {"refId": "A", "datasource": "${DS_PROMETHEUS}",
         "expr": "sum (inquisition_misconfigurations_total{target=~\"$target\"})", "instant": true}
      ]
    }
  ]
}
